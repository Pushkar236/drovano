{
  "name": "@drovano/realtime",
  "version": "0.0.0",
  "private": true,
  "description": "Realtime gateway: session-authenticated WebSockets fanning out Redis invalidation events per tenant (ADR-0003)",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsup",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "catalog:",
    "@drovano/api-contracts": "workspace:*",
    "@drovano/db": "workspace:*",
    "@drovano/identity": "workspace:*",
    "@node-rs/argon2": "catalog:",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "ioredis": "catalog:",
    "pg": "catalog:",
    "uuid": "catalog:",
    "ws": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@drovano/config": "workspace:*",
    "@testcontainers/redis": "catalog:",
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
