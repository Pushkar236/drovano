# Copy to .env and fill in. Real values live only in .env (gitignored) and
# the platform's environment store (SECURITY.md) — never in git or docs.

# App-role connection (pooled endpoint, drovano_app_login credentials).
DATABASE_URL=postgres://drovano_app_login:<password>@<pooler-host>/<db>?sslmode=require

# Session/token signing secret, >= 32 chars.
AUTH_SECRET=

# Public origin the auth endpoints are served from.
BASE_URL=http://localhost:3000

# Optional
PORT=3000
SENTRY_DSN=
# staging | production | development (defaults to development)
DEPLOY_ENV=development
