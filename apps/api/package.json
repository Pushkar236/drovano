{
  "name": "@drovano/api",
  "version": "0.0.0",
  "private": true,
  "description": "Drovano API — Hono modular monolith (ADR-0004)",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx watch --env-file=.env src/main.ts",
    "dev:trigger": "trigger dev --env-file .env --skip-update-check",
    "deploy:trigger": "trigger deploy --skip-update-check",
    "build": "tsup",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@better-auth/drizzle-adapter": "catalog:",
    "@huggingface/transformers": "catalog:",
    "@drovano/agents": "workspace:*",
    "@drovano/ai": "workspace:*",
    "@drovano/api-contracts": "workspace:*",
    "@drovano/crm": "workspace:*",
    "@drovano/retrieval": "workspace:*",
    "@drovano/db": "workspace:*",
    "@drovano/google": "workspace:*",
    "@hono/trpc-server": "catalog:",
    "@trigger.dev/sdk": "catalog:",
    "@trpc/server": "catalog:",
    "@drovano/identity": "workspace:*",
    "@drovano/permissions": "workspace:*",
    "@drovano/platform": "workspace:*",
    "@drovano/telemetry": "workspace:*",
    "@hono/node-server": "catalog:",
    "@node-rs/argon2": "catalog:",
    "@sentry/node": "catalog:",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "ioredis": "catalog:",
    "pg": "catalog:",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@drovano/config": "workspace:*",
    "@trigger.dev/build": "catalog:",
    "trigger.dev": "catalog:",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
