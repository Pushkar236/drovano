{
  "name": "drovano",
  "private": true,
  "version": "0.0.0",
  "description": "Drovano — an AI-native Business Operating System",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "eslint . --max-warnings 0",
    "boundaries": "turbo boundaries",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify-docs": "tsx scripts/src/verify-docs.ts",
    "check-bundle": "tsx scripts/src/check-bundle-size.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,jsonc,md,yaml,yml}": "prettier --write"
  }
}
