{
  "$description": "Strata design tokens (DESIGN_SYSTEM.md, ADR-0009). W3C DTCG format. Three tiers: color/space/font/motion primitives, theme.* semantic tiers (light/dark must define identical keys), component tokens arrive with component specs (TASK-0013+). Color values are OKLCH; the contrast contract in src/contrast-contract.test.ts is the merge gate for any change here.",
  "color": {
    "$type": "color",
    "neutral": {
      "$description": "Cool graphite ramp, hue 255. Fixed lightness steps so themes derive systematically. No pure black: dark surfaces bottom out at neutral-1000.",
      "0": { "$value": { "colorSpace": "oklch", "components": [1, 0, 0] } },
      "50": { "$value": { "colorSpace": "oklch", "components": [0.985, 0.003, 255] } },
      "100": { "$value": { "colorSpace": "oklch", "components": [0.965, 0.004, 255] } },
      "200": { "$value": { "colorSpace": "oklch", "components": [0.92, 0.006, 255] } },
      "300": { "$value": { "colorSpace": "oklch", "components": [0.86, 0.008, 255] } },
      "400": { "$value": { "colorSpace": "oklch", "components": [0.74, 0.01, 255] } },
      "500": { "$value": { "colorSpace": "oklch", "components": [0.62, 0.012, 255] } },
      "600": { "$value": { "colorSpace": "oklch", "components": [0.52, 0.012, 255] } },
      "700": { "$value": { "colorSpace": "oklch", "components": [0.42, 0.01, 255] } },
      "800": { "$value": { "colorSpace": "oklch", "components": [0.32, 0.008, 255] } },
      "850": { "$value": { "colorSpace": "oklch", "components": [0.27, 0.007, 255] } },
      "900": { "$value": { "colorSpace": "oklch", "components": [0.22, 0.006, 255] } },
      "950": { "$value": { "colorSpace": "oklch", "components": [0.17, 0.005, 255] } },
      "1000": { "$value": { "colorSpace": "oklch", "components": [0.13, 0.004, 255] } }
    },
    "ember": {
      "$description": "The single accent (DESIGN_SYSTEM.md rule 1): warm orange-copper, hue 52 — deliberately counter to the category's cool accents.",
      "100": { "$value": { "colorSpace": "oklch", "components": [0.93, 0.032, 52] } },
      "200": { "$value": { "colorSpace": "oklch", "components": [0.88, 0.07, 52] } },
      "300": { "$value": { "colorSpace": "oklch", "components": [0.8, 0.11, 52] } },
      "400": { "$value": { "colorSpace": "oklch", "components": [0.72, 0.14, 52] } },
      "500": { "$value": { "colorSpace": "oklch", "components": [0.63, 0.155, 52] } },
      "600": { "$value": { "colorSpace": "oklch", "components": [0.55, 0.14, 52] } },
      "700": { "$value": { "colorSpace": "oklch", "components": [0.47, 0.12, 52] } },
      "800": { "$value": { "colorSpace": "oklch", "components": [0.39, 0.095, 52] } }
    },
    "green": {
      "$description": "Semantic hue: success only, never decoration.",
      "400": { "$value": { "colorSpace": "oklch", "components": [0.72, 0.14, 152] } },
      "600": { "$value": { "colorSpace": "oklch", "components": [0.53, 0.12, 152] } },
      "700": { "$value": { "colorSpace": "oklch", "components": [0.45, 0.1, 152] } }
    },
    "amber": {
      "$description": "Semantic hue: warning only.",
      "400": { "$value": { "colorSpace": "oklch", "components": [0.75, 0.13, 80] } },
      "600": { "$value": { "colorSpace": "oklch", "components": [0.55, 0.11, 80] } },
      "700": { "$value": { "colorSpace": "oklch", "components": [0.47, 0.09, 80] } }
    },
    "red": {
      "$description": "Semantic hue: danger only.",
      "400": { "$value": { "colorSpace": "oklch", "components": [0.7, 0.16, 27] } },
      "600": { "$value": { "colorSpace": "oklch", "components": [0.53, 0.17, 27] } },
      "700": { "$value": { "colorSpace": "oklch", "components": [0.45, 0.15, 27] } }
    },
    "blue": {
      "$description": "Semantic hue: info only.",
      "400": { "$value": { "colorSpace": "oklch", "components": [0.7, 0.13, 245] } },
      "600": { "$value": { "colorSpace": "oklch", "components": [0.52, 0.12, 245] } },
      "700": { "$value": { "colorSpace": "oklch", "components": [0.44, 0.1, 245] } }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "4px grid (DESIGN_SYSTEM.md rule 5). Names are grid multiples; values are rem at 16px root.",
    "0": { "$value": { "value": 0, "unit": "rem" } },
    "0-5": { "$value": { "value": 0.125, "unit": "rem" } },
    "1": { "$value": { "value": 0.25, "unit": "rem" } },
    "1-5": { "$value": { "value": 0.375, "unit": "rem" } },
    "2": { "$value": { "value": 0.5, "unit": "rem" } },
    "3": { "$value": { "value": 0.75, "unit": "rem" } },
    "4": { "$value": { "value": 1, "unit": "rem" } },
    "5": { "$value": { "value": 1.25, "unit": "rem" } },
    "6": { "$value": { "value": 1.5, "unit": "rem" } },
    "8": { "$value": { "value": 2, "unit": "rem" } },
    "10": { "$value": { "value": 2.5, "unit": "rem" } },
    "12": { "$value": { "value": 3, "unit": "rem" } },
    "16": { "$value": { "value": 4, "unit": "rem" } },
    "20": { "$value": { "value": 5, "unit": "rem" } },
    "24": { "$value": { "value": 6, "unit": "rem" } }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "$description": "Interim system stacks — the purchased faces land with TASK-0012 (typography evaluation).",
      "sans": { "$value": ["system-ui", "-apple-system", "Segoe UI", "sans-serif"] },
      "mono": { "$value": ["ui-monospace", "Cascadia Mono", "Consolas", "monospace"] }
    },
    "size": {
      "$type": "dimension",
      "$description": "Work-surface body is 13–14px (DESIGN_SYSTEM.md rule 4); hierarchy comes from weight, not size sprawl.",
      "xs": { "$value": { "value": 0.6875, "unit": "rem" } },
      "sm": { "$value": { "value": 0.75, "unit": "rem" } },
      "base": { "$value": { "value": 0.8125, "unit": "rem" } },
      "md": { "$value": { "value": 0.875, "unit": "rem" } },
      "lg": { "$value": { "value": 1, "unit": "rem" } },
      "xl": { "$value": { "value": 1.25, "unit": "rem" } },
      "2xl": { "$value": { "value": 1.5, "unit": "rem" } },
      "3xl": { "$value": { "value": 2, "unit": "rem" } }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 }
    },
    "line-height": {
      "$type": "number",
      "tight": { "$value": 1.2 },
      "snug": { "$value": 1.35 },
      "base": { "$value": 1.5 }
    }
  },
  "duration": {
    "$type": "duration",
    "$description": "The three motion durations (DESIGN_SYSTEM.md rule 8).",
    "fast": { "$value": { "value": 120, "unit": "ms" } },
    "base": { "$value": { "value": 200, "unit": "ms" } },
    "slow": { "$value": { "value": 320, "unit": "ms" } }
  },
  "easing": {
    "$type": "cubicBezier",
    "out": { "$value": [0.2, 0, 0, 1] },
    "in-out": { "$value": [0.4, 0, 0.2, 1] }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": { "value": 0.25, "unit": "rem" } },
    "md": { "$value": { "value": 0.375, "unit": "rem" } },
    "lg": { "$value": { "value": 0.5, "unit": "rem" } },
    "xl": { "$value": { "value": 0.75, "unit": "rem" } },
    "full": { "$value": { "value": 624.9375, "unit": "rem" } }
  },
  "z": {
    "$type": "number",
    "$description": "Stacking contexts; only true overlays float (DESIGN_SYSTEM.md rule 3).",
    "dropdown": { "$value": 1000 },
    "sticky": { "$value": 1100 },
    "overlay": { "$value": 1200 },
    "modal": { "$value": 1300 },
    "toast": { "$value": 1400 }
  },
  "theme": {
    "$description": "Semantic tier. light and dark MUST define identical keys (the builder fails otherwise); components reference only these, never primitives (ADR-0009).",
    "light": {
      "$type": "color",
      "surface-base": { "$value": "{color.neutral.50}" },
      "surface-raised": { "$value": "{color.neutral.0}" },
      "surface-overlay": { "$value": "{color.neutral.0}" },
      "surface-sunken": { "$value": "{color.neutral.100}" },
      "text-primary": { "$value": "{color.neutral.950}" },
      "text-secondary": { "$value": "{color.neutral.700}" },
      "text-muted": { "$value": "{color.neutral.600}" },
      "text-on-accent": { "$value": "{color.neutral.0}" },
      "text-accent": { "$value": "{color.ember.700}" },
      "border-hairline": { "$value": "{color.neutral.200}" },
      "border-strong": { "$value": "{color.neutral.300}" },
      "accent-solid": { "$value": "{color.ember.600}" },
      "accent-hover": { "$value": "{color.ember.700}" },
      "accent-active": { "$value": "{color.ember.800}" },
      "accent-subtle": { "$value": "{color.ember.100}" },
      "focus-ring": { "$value": "{color.ember.500}" },
      "status-success-text": { "$value": "{color.green.700}" },
      "status-success-solid": { "$value": "{color.green.600}" },
      "status-warning-text": { "$value": "{color.amber.700}" },
      "status-warning-solid": { "$value": "{color.amber.600}" },
      "status-danger-text": { "$value": "{color.red.700}" },
      "status-danger-solid": { "$value": "{color.red.600}" },
      "status-info-text": { "$value": "{color.blue.700}" },
      "status-info-solid": { "$value": "{color.blue.600}" }
    },
    "dark": {
      "$type": "color",
      "surface-base": { "$value": "{color.neutral.950}" },
      "surface-raised": { "$value": "{color.neutral.900}" },
      "surface-overlay": { "$value": "{color.neutral.850}" },
      "surface-sunken": { "$value": "{color.neutral.1000}" },
      "text-primary": { "$value": "{color.neutral.50}" },
      "text-secondary": { "$value": "{color.neutral.300}" },
      "text-muted": { "$value": "{color.neutral.400}" },
      "text-on-accent": { "$value": "{color.neutral.0}" },
      "text-accent": { "$value": "{color.ember.400}" },
      "border-hairline": { "$value": "{color.neutral.800}" },
      "border-strong": { "$value": "{color.neutral.700}" },
      "accent-solid": { "$value": "{color.ember.600}" },
      "accent-hover": { "$value": "{color.ember.700}" },
      "accent-active": { "$value": "{color.ember.800}" },
      "accent-subtle": { "$value": "{color.ember.800}" },
      "focus-ring": { "$value": "{color.ember.400}" },
      "status-success-text": { "$value": "{color.green.400}" },
      "status-success-solid": { "$value": "{color.green.600}" },
      "status-warning-text": { "$value": "{color.amber.400}" },
      "status-warning-solid": { "$value": "{color.amber.600}" },
      "status-danger-text": { "$value": "{color.red.400}" },
      "status-danger-solid": { "$value": "{color.red.600}" },
      "status-info-text": { "$value": "{color.blue.400}" },
      "status-info-solid": { "$value": "{color.blue.600}" }
    }
  }
}
