{
  "name": "@drovano/db",
  "version": "0.0.0",
  "private": true,
  "description": "Database layer: Drizzle schema, RLS policies as code, migrations, and the tenant-scoped connection helper",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./test/harness.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@drovano/config": "workspace:*",
    "@testcontainers/postgresql": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
